{
  "name": "ngxs",
  "version": "22.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ngxs/store.git"
  },
  "keywords": [
    "ngxs",
    "redux",
    "state",
    "rxjs",
    "angular",
    "ngx",
    "angular2",
    "cqrs",
    "store",
    "state-management",
    "event-stream"
  ],
  "author": "Austin McDaniel",
  "contributors": [
    {
      "name": "Mark Whitfeld"
    },
    {
      "name": "Artur Androsovych"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ngxs/store/issues"
  },
  "homepage": "https://github.com/ngxs/store#readme",
  "packageScope": "@ngxs",
  "packages": [
    "packages/store",
    "packages/logger-plugin",
    "packages/devtools-plugin",
    "packages/storage-plugin",
    "packages/websocket-plugin",
    "packages/form-plugin",
    "packages/router-plugin",
    "packages/hmr-plugin"
  ],
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/ngxs"
  },
  "scripts": {
    "preinstall": "node -e \"if(process.env.npm_execpath.indexOf('yarn') === -1) throw new Error('You must use Yarn to install, not NPM')\"",
    "postinstall": "husky install",
    "// - Binaries": "Run against node_modules/.bin",
    "ng": "nx",
    "nx": "nx",
    "ts-node": "ts-node",
    "prettier": "prettier",
    "// - APPS": "Run Apps in dev and with packaged modules",
    "start": "yarn serve:hmr:integration",
    "serve:integration": "nx serve integration -c production #requires yarn package",
    "serve:hmr:integration": "nx serve integration --aot --open -c hmr",
    "serve:integration:static": "serve dist-integration -s -l 4200 --cors",
    "serve:integration:ssr": "node dist-integration/server/server.mjs",
    "// - BUILDING": "Run Apps in dev and with packaged modules",
    "build": "yarn build:packages",
    "postbuild": "node ./build/copy-license.mjs",
    "build:packages": "yarn nx run-many --target=build --all && ts-node tools/set-metadata",
    "// - INTEGRATION BUILDS": "#requires yarn build",
    "build:integration": "nx build integration -c production",
    "// - TESTING": "Test all modules #requires yarn build:packages",
    "test:integration": "nx run integration:test --colors --run-in-band",
    "test:types": "nx lint-types store",
    "// - E2E": "E2E testing #requires yarn build:integration",
    "e2e": "playwright test --ui",
    "e2e:ssr": "cross-env SSR=true playwright test --ui",
    "e2e:headless": "playwright test",
    "// - CI": "CI Testing",
    "test": "nx run-many --target=test --all",
    "test:ci:e2e": "cross-env CI=true playwright test",
    "test:ci:integration": "cross-env CI=true nx run integration:test --colors --run-in-band && yarn build:integration",
    "test:ci:integration:ssr": "cross-env CI=true SSR=true yarn build:integration && playwright test",
    "bundlemon": "bundlemon --config .bundlemonrc.json; bundlemon --config .bundlemonrc.plugins.json; bundlemon --config .bundlemonrc.integration.json; echo .",
    "publish:dev": "ts-node tools/publish-dev-builds",
    "publish:tagged": "ts-node tools/publish-tagged-builds",
    "// - UTILS": "Utility Scripts",
    "format": "nx format:write",
    "// - INTEGRATION": "Integration builds",
    "integration:ng22": "cd integrations/hello-world-ng22 && yarn test:integration",
    "version:integration": "npm-run-all build version:integration:*",
    "version:integration:ng22": "cd integrations/hello-world-ng22 && yarn install --force && cd ../..",
    "// - INTEGRATION END -": "----------",
    "tutorials:install": "yarn --cwd tutorials/create-app/ install --frozen-lockfile --non-interactive"
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.28",
    "@angular-devkit/core": "20.3.28",
    "@angular-devkit/schematics": "20.3.28",
    "@angular-devkit/schematics-cli": "20.3.28",
    "@angular/animations": "20.3.25",
    "@angular/build": "20.3.28",
    "@angular/cli": "~20.3.28",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/compiler-cli": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/language-service": "20.3.25",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@angular/platform-server": "20.3.25",
    "@angular/router": "20.3.25",
    "@angular/ssr": "20.3.28",
    "@commitlint/cli": "^17.6.0",
    "@commitlint/config-conventional": "^17.6.0",
    "@nx/angular": "22.7.5",
    "@nx/eslint": "22.7.5",
    "@nx/jest": "22.7.5",
    "@nx/js": "22.7.5",
    "@nx/workspace": "22.7.5",
    "@playwright/test": "^1.61.1",
    "@schematics/angular": "20.3.28",
    "@types/express": "^4.17.6",
    "@types/jest": "29.5.14",
    "@types/node": "^20.11.1",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "bundlemon": "3.1.0",
    "cpx2": "^2.0.0",
    "cross-env": "^5.2.1",
    "eslint": "8.57.0",
    "eslint-plugin-expect-type": "0.6.2",
    "express": "^4.17.1",
    "husky": "^8.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-preset-angular": "14.6.0",
    "lint-staged": "^13.0.0",
    "mock-socket": "^8.1.0",
    "ng-packagr": "20.3.0",
    "npm-run-all": "^4.1.5",
    "nx": "22.7.5",
    "prettier": "3.8.4",
    "rxjs": "^7.8.2",
    "serve": "^14.2.6",
    "ts-jest": "29.4.11",
    "ts-morph": "^21.0.1",
    "ts-node": "^8.10.2",
    "tslib": "^2.8.1",
    "typescript": "5.9.3",
    "zone.js": "~0.16.2"
  },
  "resolutions": {
    "tmp": "^0.2.7"
  }
}
